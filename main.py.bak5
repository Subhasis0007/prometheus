import typer
from rich.console import Console
from rich.table import Table
from rich.markdown import Markdown
from typing import TypedDict, List, Optional, Any
from langgraph.graph import StateGraph, END
from datetime import datetime
import os
import glob
import re

from prometheus_planner_agent import boot_agent, create_plan, UserGoal
from prometheus_coder_agent import execute as coder_execute, ThoughtStream as CoderStream
from prometheus_reviewer_agent import evaluate as reviewer_evaluate, ThoughtStream as ReviewerStream, Traceback
from prometheus_executor_agent import run_code
from prometheus_fs_agent import write_to_disk

console = Console()
MAX_RETRIES_PER_STEP = 5

class PrometheusState(TypedDict):
    goal: str
    output_file: str
    plan: List[str]
    current_step_index: int
    working_memory: str
    traceback_ledger: List[dict]
    last_patch: Optional[str]
    final_code: str
    status: str
    model: Any
    tokenizer: Any
    last_error: Optional[str]
    current_step_retries: int

def planner_node(state: PrometheusState) -> PrometheusState:
    console.rule("[bold blue]PLANNER[/bold blue]")
    model, tok = boot_agent()
    plan = create_plan(UserGoal(goal=state["goal"]), model, tok)
    
    console.print("[green]Generated Plan:[/green]")
    for i, step in enumerate(plan, 1):
        console.print(f"  {i}. {step}")
    
    return {
        **state,
        "plan": plan,
        "current_step_index": 0,
        "working_memory": "",
        "traceback_ledger": [],
        "model": model,
        "tokenizer": tok,
        "last_error": None,
        "current_step_retries": 0,
        "status": "planning_done"
    }

def coder_node(state: PrometheusState) -> PrometheusState:
    step_num = state["current_step_index"] + 1
    retry = state.get("current_step_retries", 0)
    console.rule(f"[bold cyan]CODER → Step {step_num}/{len(state['plan'])} (retry {retry})[/bold cyan]")
    
    model = state["model"]
    tok = state["tokenizer"]
    task = state["plan"][state["current_step_index"]]

    context = state["working_memory"]
    if state.get("last_error"):
        context += f"""\n\n[PREVIOUS ERROR + STRICT RULES]:
{state['last_error']}

IMPORTANT RULES FOR THIS FIX:
- Use ONLY Python standard library (csv, sys, os, etc.). NEVER import pandas, numpy or any external library unless the goal explicitly requires it.
- Do not repeat the same mistake from before.
- Write clean, complete and runnable code for ONLY this step.
- Fix the exact error shown above."""

    stream = CoderStream(task=task, campaign_context=context)
    new_code = coder_execute(stream, model, tok)

    return {
        **state,
        "last_patch": new_code,
        "last_error": None,
        "status": "coding_done"
    }

def reviewer_node(state: PrometheusState) -> PrometheusState:
    console.rule("[bold yellow]REVIEWER[/bold yellow]")
    model = state["model"]
    tok = state["tokenizer"]
    task = state["plan"][state["current_step_index"]]
    review = reviewer_evaluate(ReviewerStream(task=task, artifact=state["last_patch"]), model, tok)

    if isinstance(review, Traceback):
        console.print("[red]✗ Rejected by Reviewer[/red]")
        ledger = state.get("traceback_ledger", []) + [{"step": state["current_step_index"], "error": review.error_message}]
        return {**state, "traceback_ledger": ledger, "status": "review_rejected"}
    else:
        console.print("[green]✓ Approved by Reviewer[/green]")
        return {**state, "working_memory": review, "status": "review_approved"}

def executor_node(state: PrometheusState) -> PrometheusState:
    console.rule("[bold magenta]EXECUTOR[/bold magenta]")
    success, output = run_code(state["working_memory"])

    if success:
        console.print("[green]✓ Execution successful[/green]")
        new_index = state["current_step_index"] + 1
        return {
            **state,
            "current_step_index": new_index,
            "final_code": state["working_memory"],
            "last_error": None,
            "current_step_retries": 0,
            "status": "execution_success"
        }
    else:
        retries = state.get("current_step_retries", 0) + 1
        console.print(f"[red]✗ Execution failed (retry {retries}/{MAX_RETRIES_PER_STEP})[/red]")
        error_preview = output[:1200] + "..." if len(output) > 1200 else output
        console.print(f"[dim]{error_preview}[/dim]")

        if retries >= MAX_RETRIES_PER_STEP:
            console.print(f"[bold red]Max retries reached on step {state['current_step_index'] + 1}[/bold red]")
            return {
                **state,
                "last_error": output,
                "current_step_retries": retries,
                "status": "max_retries_exceeded"
            }

        return {
            **state,
            "last_error": output,
            "current_step_retries": retries,
            "status": "execution_failed_with_error"
        }

def should_continue(state: PrometheusState) -> str:
    if state["status"] == "execution_success":
        if state["current_step_index"] < len(state["plan"]):
            return "next_step"
        else:
            return "finish"
    elif state["status"] == "max_retries_exceeded":
        return "finish"
    elif state["status"] in ["execution_failed_with_error", "review_rejected"]:
        return "coder"
    return "coder"

def build_graph():
    workflow = StateGraph(PrometheusState)
    workflow.add_node("planner", planner_node)
    workflow.add_node("coder", coder_node)
    workflow.add_node("reviewer", reviewer_node)
    workflow.add_node("executor", executor_node)
    workflow.set_entry_point("planner")
    workflow.add_edge("planner", "coder")
    workflow.add_edge("coder", "reviewer")
    workflow.add_edge("reviewer", "executor")
    workflow.add_conditional_edges("executor", should_continue, {
        "next_step": "coder",
        "finish": END,
        "coder": "coder"
    })
    return workflow.compile()

def log_run_report(state: dict, output_file: str):
    os.makedirs("artifacts/run_reports", exist_ok=True)
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    report_name = f"run_{timestamp}_{output_file.replace('.py', '')}.md"
    report_path = os.path.join("artifacts/run_reports", report_name)
    
    plan_md = "\n".join([f"{i+1}. {step}" for i, step in enumerate(state.get("plan", []))])
    retries = len(state.get("traceback_ledger", []))
    steps_completed = state.get("current_step_index", 0)
    total_steps = len(state.get("plan", []))
    status = "SUCCESS" if state.get("final_code") else "PARTIAL / STOPPED"
    final_code = state.get("final_code", "# No final code generated")
    
    report = "# Prometheus Run Report\n\n"
    report += f"**Timestamp:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
    report += f"**Goal:** {state.get('goal', 'N/A')}\n"
    report += f"**Output File:** `artifacts/{output_file}`\n"
    report += f"**Status:** {status}\n\n"
    report += f"## Plan ({total_steps} steps)\n\n{plan_md}\n\n"
    report += "## Execution Summary\n\n"
    report += f"- **Steps Completed:** {steps_completed}/{total_steps}\n"
    report += f"- **Total Retries:** {retries}\n"
    report += f"- **Final Status:** {state.get('status', 'unknown')}\n\n"
    report += "## Generated Code\n\n"
    report += "```python\n"
    report += final_code + "\n"
    report += "```\n\n"
    report += "---\n*Generated by Prometheus (LangGraph + Error Feedback)*\n"
    
    with open(report_path, "w") as f:
        f.write(report)
    
    console.print(f"[dim]Run report saved → {report_path}[/dim]")

def get_run_reports():
    reports_dir = "artifacts/run_reports"
    if not os.path.exists(reports_dir):
        return []
    return sorted(glob.glob(os.path.join(reports_dir, "run_*.md")), reverse=True)

def extract_goal_from_report(report_path: str) -> Optional[str]:
    try:
        with open(report_path, "r") as f:
            content = f.read()
        match = re.search(r'\*\*Goal:\*\* (.+?)(?:\n|$)', content)
        if match:
            return match.group(1).strip()
    except:
        pass
    return None

def extract_output_file_from_report(report_path: str) -> Optional[str]:
    try:
        with open(report_path, "r") as f:
            content = f.read()
        match = re.search(r'\*\*Output File:\*\* `artifacts/(.+?)`', content)
        if match:
            return match.group(1).strip()
    except:
        pass
    return None

app = typer.Typer()

@app.command()
def start(
    goal: str = typer.Option(..., "--goal", "-g"),
    output: str = typer.Option("output.py", "--output", "-o")
):
    console.print(f"\n[bold green]🚀 Starting Prometheus[/bold green]")
    console.print(f"[dim]Goal:[/dim] {goal}\n")

    graph = build_graph()
    initial_state: PrometheusState = {
        "goal": goal,
        "output_file": output,
        "plan": [],
        "current_step_index": 0,
        "working_memory": "",
        "traceback_ledger": [],
        "last_patch": None,
        "final_code": "",
        "status": "started",
        "model": None,
        "tokenizer": None,
        "last_error": None,
        "current_step_retries": 0
    }

    final_state = graph.invoke(initial_state)

    console.rule("[bold green]FINAL SUMMARY[/bold green]")
    console.print(f"Steps completed: {final_state['current_step_index']}/{len(final_state['plan'])}")
    console.print(f"Total retries used: {len(final_state.get('traceback_ledger', []))}")
    
    if final_state.get("final_code"):
        write_to_disk(output, final_state["final_code"])
        console.print(f"[bold green]✓ DONE → artifacts/{output}[/bold green]")
    else:
        console.print("[red]Process stopped early.[/red]")
    
    log_run_report(final_state, output)

@app.command()
def history():
    """List previous runs"""
    reports = get_run_reports()
    
    if not reports:
        console.print("[yellow]No run reports found yet.[/yellow]")
        return
    
    table = Table(title="Prometheus Run History")
    table.add_column("#", style="cyan", justify="right")
    table.add_column("Timestamp", style="green")
    table.add_column("Goal", style="white")
    table.add_column("Status", style="magenta")
    
    for idx, report_path in enumerate(reports[:20], 1):
        filename = os.path.basename(report_path)
        try:
            parts = filename.replace(".md", "").split("_")
            timestamp = f"{parts[1]} {parts[2].replace('-', ':')}"
        except:
            timestamp = "Unknown"
        
        try:
            with open(report_path, "r") as f:
                content = f.read()
                goal_line = content.split("**Goal:**")[1].split("\n")[0].strip() if "**Goal:**" in content else "N/A"
                status = content.split("**Status:**")[1].split("\n")[0].strip() if "**Status:**" in content else "Unknown"
        except:
            goal_line = "N/A"
            status = "Unknown"
        
        table.add_row(str(idx), timestamp, goal_line[:65], status)
    
    console.print(table)
    console.print(f"\n[dim]Total runs: {len(reports)} | Use 'show <number>' or 'rerun <number>'[/dim]")

@app.command()
def show(run_number: int = typer.Argument(1, help="Run number from history")):
    """Show full report of a previous run"""
    reports = get_run_reports()
    
    if not reports:
        console.print("[yellow]No run reports found.[/yellow]")
        return
    
    if run_number < 1 or run_number > len(reports):
        console.print(f"[red]Invalid run number. Available: 1 to {len(reports)}[/red]")
        return
    
    report_path = reports[run_number - 1]
    
    try:
        with open(report_path, "r") as f:
            content = f.read()
        
        console.rule(f"[bold blue]Run Report #{run_number}[/bold blue]")
        console.print(Markdown(content))
        
    except Exception as e:
        console.print(f"[red]Error reading report: {e}[/red]")

@app.command()
def rerun(run_number: int = typer.Argument(1, help="Run number from history to re-execute")):
    """Re-run a previous goal"""
    reports = get_run_reports()
    
    if not reports:
        console.print("[yellow]No run reports found.[/yellow]")
        return
    
    if run_number < 1 or run_number > len(reports):
        console.print(f"[red]Invalid run number. Available: 1 to {len(reports)}[/red]")
        return
    
    report_path = reports[run_number - 1]
    
    goal = extract_goal_from_report(report_path)
    output_file = extract_output_file_from_report(report_path) or "output.py"
    
    if not goal:
        console.print("[red]Could not extract goal from report.[/red]")
        return
    
    console.print(f"[bold yellow]Re-running goal from run #{run_number}[/bold yellow]")
    console.print(f"[dim]Goal:[/dim] {goal}")
    console.print(f"[dim]Output will be saved to:[/dim] artifacts/{output_file}\n")
    
    # Reuse the start logic
    graph = build_graph()
    initial_state: PrometheusState = {
        "goal": goal,
        "output_file": output_file,
        "plan": [],
        "current_step_index": 0,
        "working_memory": "",
        "traceback_ledger": [],
        "last_patch": None,
        "final_code": "",
        "status": "started",
        "model": None,
        "tokenizer": None,
        "last_error": None,
        "current_step_retries": 0
    }

    final_state = graph.invoke(initial_state)

    console.rule("[bold green]FINAL SUMMARY[/bold green]")
    console.print(f"Steps completed: {final_state['current_step_index']}/{len(final_state['plan'])}")
    console.print(f"Total retries used: {len(final_state.get('traceback_ledger', []))}")
    
    if final_state.get("final_code"):
        write_to_disk(output_file, final_state["final_code"])
        console.print(f"[bold green]✓ DONE → artifacts/{output_file}[/bold green]")
    else:
        console.print("[red]Process stopped early.[/red]")
    
    log_run_report(final_state, output_file)

@app.command()
def status():
    console.print("[bold green]Prometheus is ready[/bold green]")

if __name__ == "__main__":
    app()
